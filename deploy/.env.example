# Copy to deploy/.env and adjust. Joern HTTP API: https://docs.joern.io/server/

# Host port published to your machine
JOERN_PUBLISH_PORT=8080

# Internal Joern HTTP server port (proxy forwards /query-sync to this).
JOERN_INTERNAL_PORT=18080

# Proxy timeout (seconds) for forwarding /query-sync to Joern internal server.
# Increase for heavy importCpg/reachableByFlows queries to avoid 502 {"error":"timed out"}.
JOERN_QUERY_TIMEOUT_SEC=600

# MCP SSE server port (used by AI clients for MCP tool calls).
MCP_PUBLISH_PORT=9000

# Router mode: host port published by HAProxy (deploy/docker-compose.router.yml).
JOERN_ROUTER_PUBLISH_PORT=8080

# MCP SSE server bind address inside the container (default 0.0.0.0 = all interfaces).
MCP_HOST=0.0.0.0

# JVM *heap* max (passed as -J-Xmx). Joern still needs non-heap memory on top of this.
# OPTIMIZED FOR SMALL CODEBASES (10-200 LOC): Reduced from 20g to 1g
JOERN_JAVA_XMX=1g

# Docker cgroup memory cap for the *entire* container (Joern JVM + Python proxy + MCP).
# OPTIMIZED FOR SMALL CODEBASES (10-200 LOC): Reduced from 32g to 4g
# With JOERN_JAVA_XMX=1g, we have ~3g headroom for non-heap JVM memory, proxy, and MCP server.
# This is sufficient for small codebases with simple queries.
JOERN_MEMORY_LIMIT=4g

# Image tag for local builds
JOERN_IMAGE_TAG=local

# Strongly recommended: HTTP basic auth (both must be set to enable)
JOERN_SERVER_AUTH_USERNAME=joern
JOERN_SERVER_AUTH_PASSWORD=change-me

# Unset auth in .env to run without basic auth (dev only; not for untrusted networks)

# Optional self-healing watcher for unhealthy containers (used by docker-compose*.yml):
# - AUTOHEAL_INTERVAL: poll period in seconds.
# - AUTOHEAL_START_PERIOD: grace period in seconds after container start.
AUTOHEAL_INTERVAL=10
AUTOHEAL_START_PERIOD=180

# Optional for deploy/run-joern.sh (standalone runner):
# JOERN_INTERNAL_PORT=18080
# JOERN_IMPORT_SC=/app/mcp-joern/server_tools.sc
